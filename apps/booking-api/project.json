{
  "name": "@org/booking-api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/booking-api/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm --workspace @org/booking-api run build"
      },
      "outputs": ["{workspaceRoot}/dist/apps/booking-api"]
    },
    "start": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "npm --workspace @org/booking-api run start"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm --workspace @org/booking-api run dev"
      }
    }
  },
  "tags": []
}
